{
  "name": "@contextcompany/openclaw",
  "version": "1.0.0",
  "description": "The Context Company integration for OpenClaw via OpenTelemetry",
  "type": "module",
  "bin": {
    "openclaw-collector": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build --watch",
    "start": "node dist/cli.js"
  },
  "sideEffects": false,
  "keywords": [
    "openclaw",
    "opentelemetry",
    "otlp",
    "observability",
    "tracing",
    "monitoring",
    "context-company"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Context-Company/observatory",
    "directory": "packages/ts/openclaw"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@contextcompany/api": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
